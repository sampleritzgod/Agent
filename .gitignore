# Collected ingestion data.
# NOTE: chunks and ingestion/raw are READ AT RUNTIME by the deployed chat API
# (transcript context + video recommendations). This app has no database, so
# these must be committed for the Vercel deployment to work. The intermediate
# pipeline artifacts below are build-time only and stay ignored.
src/data/ingestion/normalized/*
!src/data/ingestion/normalized/.gitkeep
src/data/transcripts/*
!src/data/transcripts/.gitkeep
src/data/cleaned-transcripts/*
!src/data/cleaned-transcripts/.gitkeep
src/data/transliterated-transcripts/*
!src/data/transliterated-transcripts/.gitkeep
src/data/embeddings/*
!src/data/embeddings/.gitkeep

# Local tooling
.DS_Store
.turbo/
.vercel/

