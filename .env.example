OPENAI_CHAT_MAX_HISTORY=10
OPENAI_CHAT_MAX_CONTEXT_CHUNKS=6
OPENAI_CHAT_TIMEOUT_MS=60000
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Qdrant
QDRANT_URL=
