# Redis
REDIS_URL=

# Conversation Memory
CONVERSATION_MEMORY_MAX_RECENT_MESSAGES=
CONVERSATION_MEMORY_MAX_CONTEXT_TOKENS=
CONVERSATION_MEMORY_MAX_SUMMARY_CHARS=

# PostgreSQL
DATABASE_URL=

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# Security
